# Copia este archivo a .env y cambia los valores antes de desplegar:
#   cp .env.example .env

# Dominio DuckDNS apuntando a la IP pública de la VM (HTTPS vía Caddy)
DOMAIN=meditrack-organization.duckdns.org
PUBLIC_BASE_URL=https://meditrack-organization.duckdns.org
# Include Firebase Hosting when calling Organization directly (Swagger, etc.)
CORS_ALLOWED_ORIGINS=https://meditrack-pro-yvaal.web.app,https://meditrack-pro-yvaal.firebaseapp.com,https://meditrack-organization.duckdns.org,http://localhost:4200

# ActiveMQ (misma VM: broker en ~/meditrack-broker)
MESSAGING_ENABLED=true
IAM_ADAPTER=jms
ACTIVEMQ_BROKER_URL=tcp://meditrack-activemq:61616
ACTIVEMQ_USER=meditrack
ACTIVEMQ_PASSWORD=cambia-este-secreto-por-uno-largo

MYSQL_ROOT_PASSWORD=root_password_segura
MYSQL_DATABASE=meditrack
MYSQL_USER=meditrack_user
MYSQL_PASSWORD=meditrack_password_segura

JWT_SECRET=un-secreto-largo-y-aleatorio-minimo-32-caracteres

# Puerto 8282 queda en 127.0.0.1 (Postman/Swagger local en la VM). /api/v1/internal/** no es público.

# REST lookups to IAM (still required with IAM_ADAPTER=jms)
IAM_BASE_URL=https://meditrack-iam-gmh0b2eshgcpbmhw.eastus-01.azurewebsites.net
DEVICES_ADAPTER=stub
